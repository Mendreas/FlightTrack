{
  "name": "flight-track-viewer",
  "version": "1.0.0",
  "description": "Flight Track Viewer — NAV Portugal",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist-win": "electron-builder --win --x64",
    "dist-mac": "electron-builder --mac",
    "dist-linux": "electron-builder --linux"
  },
  "build": {
    "appId": "pt.nav.flighttrackviewer",
    "productName": "Flight Track Viewer",
    "copyright": "NAV Portugal",
    "files": [
      "main.js",
      "index.html",
      "icon.png",
      "icon.ico"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": ["pt_PT", "en_US"],
      "language": "1816"
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
