{
  "name": "flight-track-viewer",
  "version": "1.0.0",
  "description": "Flight Track Viewer — NAV Portugal",
  "main": "main.js",
"scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64 --publish never"
},
  "build": {
    "appId": "pt.nav.flighttrackviewer",
    "productName": "Flight Track Viewer",
    "copyright": "NAV Portugal EPE",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "index.html",
      "icon.png",
      "icon.ico"
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Flight Track Viewer"
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
